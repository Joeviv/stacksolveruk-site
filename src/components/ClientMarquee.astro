---
// File: src/components/ClientMarquee.astro
// Infinite scrolling client logo banner (à la foxfifth.com).
// Logos render white via CSS filter on an always-dark band.
//
// TO ADD A CLIENT: drop the logo file in `public/clients/` and add an entry
// to `logos` below ({ name, src }). SVG preferred; PNG with transparent
// background also works. Order = display order.

interface Logo {
  name: string;
  src: string;
  scale?: number; // optional per-logo size tweak (1 = default height)
}

const logos: Logo[] = [
  { name: 'AQM (SGS)', src: '/clients/aqm-sgs.png' },
  { name: 'Cromanal (SGS)', src: '/clients/cromanal-sgs.png' },
  { name: 'Eraneos', src: '/clients/eraneos.svg', scale: 0.6 },
  { name: 'Florida Health Institute', src: '/clients/fhi.png' },
  { name: 'Sandy Port Management', src: '/clients/sandyport.webp' },
  { name: 'Wasvelt', src: '/clients/wasvelt.svg' },
  { name: 'Hispanos Sin Fronteras', src: '/clients/hispanos.png' },
];

const heading = 'Trusted by teams across the UK, Europe, the US and LATAM';

const hasLogos = logos.length > 0;
// Duplicate the list so the loop is seamless.
const track = hasLogos ? [...logos, ...logos] : [];
---

{hasLogos && (
  <section class="bg-zinc-950 border-y border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-12 lg:py-14">
      <p class="text-center text-xs font-mono uppercase tracking-widest text-zinc-500 mb-8">
        {heading}
      </p>
      <div class="marquee">
        <div class="marquee__track">
          {track.map((l, i) => (
            <img
              src={l.src}
              alt={l.name}
              class="marquee__logo"
              loading="lazy"
              style={l.scale ? `height: calc(2.25rem * ${l.scale})` : undefined}
              aria-hidden={i >= logos.length ? 'true' : undefined}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .marquee {
    overflow: hidden;
    /* Fade the edges so logos appear/disappear smoothly */
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .marquee__track {
    display: flex;
    align-items: center;
    gap: 4.5rem;
    width: max-content;
    animation: marquee-scroll 65s linear infinite;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  .marquee__logo {
    height: 2.25rem;
    width: auto;
    flex: 0 0 auto;
    /* Turn any logo (colour or black) into solid white */
    filter: brightness(0) invert(1);
    opacity: 0.55;
    transition: opacity 0.2s ease;
  }
  .marquee__logo:hover {
    opacity: 1;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track { animation: none; }
  }
</style>
