---
// File: src/components/sovereignty/EnrichedPerimeter.astro
// The "enriched perimeter" — one living macro diagram for the Fox&Stack home hero.
// Departments connect through governed access into nested rings of protection
// (Compliance → Governance → Security → Infrastructure) wrapping a living core
// where data flows 01 → 02 → 03 → 04; a severed red path shows "no data egress"
// to a public AI service.
//
// Every box / ring / department / step is a real link to its own page.
// Content/links live in src/data/sovereignArchitecture.ts (edit text there).
// Animation is CSS-only and disabled under prefers-reduced-motion.
// Concept is our own; not derived word-for-word from any third-party material.
import { RINGS, FLOW, DEPARTMENTS } from "../../data/sovereignArchitecture";

// Inline SVG icons (self-hosted, no remote dependency) keyed per ring/core.
const ICONS: Record<string, string> = {
  compliance:
    '<path d="M5 7a2 2 0 0 1 2-2h7l4 4v8a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2z"/><path d="M14 5v4h4"/><path d="m9 14 2 2 3-4"/>',
  governance:
    '<path d="M12 3v18"/><path d="M5 7h14"/><path d="m5 7-2 6a3 3 0 0 0 6 0z"/><path d="m19 7-2 6a3 3 0 0 0 6 0z"/><path d="M8 21h8"/>',
  security:
    '<path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="m9.5 12 1.8 1.8L15 10"/>',
  infrastructure:
    '<rect x="4" y="4" width="16" height="6" rx="1.5"/><rect x="4" y="14" width="16" height="6" rx="1.5"/><path d="M8 7h.01M8 17h.01"/>',
  core:
    '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v12c0 1.7 3.1 3 7 3s7-1.3 7-3V6"/><path d="M5 12c0 1.7 3.1 3 7 3s7-1.3 7-3"/>',
};

// Build the nested rings recursively, innermost = the living core.
function flowArrow(): string {
  return `<svg class="ep-arrow" width="22" height="14" viewBox="0 0 22 14" aria-hidden="true"><line x1="1" y1="7" x2="15" y2="7"/><path d="M15 4l5 3-5 3z"/></svg>`;
}
function ringIcon(key: string): string {
  return `<svg class="ep-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="${
    key === "core" ? "var(--ep-core)" : "currentColor"
  }" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${ICONS[key]}</svg>`;
}
// Renders the small "NOW · 2026" + "+2027" roadmap lines shown under a ring or
// the core header. Kept compact (mono chips) so the nested diagram never looks
// recargado. now: live items (olive); next: forward item (tenue accent).
function timelineHtml(now: string[], next: string): string {
  const nowItems = now
    .map((n) => `<span class="ep-tl-chip">${n}</span>`)
    .join("");
  return `<div class="ep-timeline"><div class="ep-tl-row ep-tl-now"><span class="ep-tl-tag">now · 2026</span>${nowItems}</div><div class="ep-tl-row ep-tl-next"><span class="ep-tl-tag">+2027</span><span class="ep-tl-chip ep-tl-chip-next">${next}</span></div></div>`;
}
function coreHtml(): string {
  const steps = FLOW.map((s, i) => {
    const arrow = i ? flowArrow() : "";
    return `${arrow}<a class="ep-step" href="${s.href}"><span class="ep-step-tag">${s.num} · ${s.label}</span></a>`;
  }).join("");
  const timeline = timelineHtml(
    ["data lineage", "open-weight", "provenance"],
    "continuous model assurance"
  );
  return `<div class="ep-core"><a class="ep-core-head" href="/data"><span style="color:var(--ep-core);display:inline-flex">${ringIcon(
    "core"
  )}</span><span class="ep-core-name">Data & models</span><span class="ep-core-tag">· the core</span></a>${timeline}<div class="ep-flow">${steps}</div></div>`;
}
function ringHtml(i: number): string {
  if (i >= RINGS.length) return coreHtml();
  const r = RINGS[i];
  return `<div class="ep-ring" style="border:1.5px solid ${r.colour}"><a class="ep-rhead" href="${
    r.href
  }"><span style="color:${r.colour};display:inline-flex">${ringIcon(
    r.id
  )}</span><span class="ep-rname">${r.label}</span><span class="ep-rhint">· ${
    r.hint
  }</span><span class="ep-open">open →</span></a>${timelineHtml(
    r.now,
    r.next
  )}<div style="margin-top:4px">${ringHtml(i + 1)}</div></div>`;
}
const ringsMarkup = ringHtml(0);
---

<figure class="ep" role="group" aria-labelledby="ep-caption">
  <figcaption id="ep-caption" class="sr-only">
    Your departments connect through governed access into nested rings of
    protection — compliance, governance, security and sovereign infrastructure —
    that wrap a living core where your data flows from data to model to private
    inference to delivery. A severed path shows that no data ever leaves to a
    public AI service. Each element links to its own page.
  </figcaption>

  <!-- Departments -->
  <div class="ep-deptlabel">Your departments</div>
  <nav class="ep-depts" aria-label="Departments using sovereign AI">
    {DEPARTMENTS.map((d) => (
      <a class="ep-dept" href={d.href}>{d.label}</a>
    ))}
  </nav>

  <div class="ep-governed" aria-hidden="true">
    <svg width="14" height="22" viewBox="0 0 14 22"><line x1="7" y1="0" x2="7" y2="14" class="ep-line-gov"/><path d="M3 14l4 6 4-6z" class="ep-fill-gov"/></svg>
    <span>governed access only</span>
  </div>

  <!-- Nested rings (outermost wraps the next, innermost wraps the core) -->
  <div class="ep-rings" set:html={ringsMarkup}></div>

  <!-- Severed path -->
  <div class="ep-severed" aria-hidden="true">
    <svg width="20" height="34" viewBox="0 0 20 34">
      <line x1="10" y1="0" x2="10" y2="24" class="ep-sev"/>
      <path d="M6 24l4 6 4-6z" class="ep-fill-sev"/>
    </svg>
    <span class="ep-noegress">No data egress</span>
  </div>

  <a class="ep-public" href="/risks#shadow-ai">
    <span class="ep-public-title">Public AI service</span>
    <span class="ep-public-sub">foreign cloud · your data leaves</span>
  </a>

  <!-- Legend -->
  <ul class="ep-legend" aria-hidden="true">
    <li><span class="ep-lg ep-lg-in"></span>inside your perimeter</li>
    <li><span class="ep-lg ep-lg-out"></span>foreign provider</li>
    <li><span class="ep-lg ep-lg-sev"></span>severed path</li>
  </ul>
</figure>

<style is:global>
  /* Scoped by the .ep prefix because the nested rings render via set:html,
     which Astro's component-scoped styles would not reach. */
  .ep {
    margin: 0;
    --ep-bd: rgba(24, 24, 27, 0.12);
    --ep-bd2: rgba(24, 24, 27, 0.22);
    --ep-txt2: var(--ss-zinc-500);
    --ep-txt3: var(--ss-zinc-400);
    --ep-surface: rgba(24, 24, 27, 0.02);
    --ep-flow: #6d8530;
    --ep-core: #85a03a;
    --ep-sevcol: #be185d;
  }
  .dark .ep {
    --ep-bd: rgba(255, 255, 255, 0.12);
    --ep-bd2: rgba(255, 255, 255, 0.22);
    --ep-txt2: #9a9b92;
    --ep-txt3: #6c6d64;
    --ep-surface: rgba(255, 255, 255, 0.02);
    --ep-flow: #a6c04d;
    --ep-core: #a6c04d;
    --ep-sevcol: #f4658f;
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap;
  }

  .ep-deptlabel {
    font-family: var(--font-mono);
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ep-txt3); margin-bottom: 8px;
  }
  .ep-depts {
    display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;
  }
  .ep-dept {
    font-size: 12.5px; line-height: 1; padding: 7px 11px;
    border-radius: var(--radius-md);
    border: 1px solid var(--ep-bd2);
    color: var(--fg-1); text-decoration: none;
    background: transparent;
    transition: border-color var(--dur-base) var(--ease-standard),
                color var(--dur-base) var(--ease-standard),
                background-color var(--dur-base) var(--ease-standard),
                transform var(--dur-base) var(--ease-standard);
  }
  .ep-dept:hover, .ep-dept:focus-visible {
    border-color: var(--ss-olive);
    color: var(--ss-olive);
    background: var(--ss-olive-soft);
    transform: translateY(-1px);
  }

  .ep-governed {
    display: flex; flex-direction: column; align-items: center;
    gap: 2px; margin: 4px 0 10px;
    font-size: 12px; color: var(--ep-txt3);
  }
  .ep-line-gov { stroke: var(--ss-olive); stroke-width: 1.4; }
  .ep-fill-gov { fill: var(--ss-olive); }

  /* ----- nested rings ----- */
  .ep-ring {
    border-radius: var(--radius-lg);
    padding: 12px 14px 14px;
    transition: box-shadow var(--dur-base) var(--ease-standard);
  }
  .ep-rhead {
    display: flex; align-items: center; gap: 8px;
    padding: 2px 0 8px; text-decoration: none; color: var(--fg-1);
  }
  .ep-rhead .ep-icon { flex: none; }
  .ep-rname { font-size: 14px; font-weight: 600; }
  .ep-rhint { font-size: 12px; color: var(--ep-txt3); }
  .ep-open {
    margin-left: auto; font-size: 11px; color: var(--ep-txt3);
    opacity: 0; transform: translateX(-3px);
    transition: opacity var(--dur-base) var(--ease-standard),
                transform var(--dur-base) var(--ease-standard);
  }
  .ep-rhead:hover .ep-open, .ep-rhead:focus-visible .ep-open {
    opacity: 1; transform: translateX(0);
  }
  .ep-rhead:hover .ep-rname, .ep-rhead:focus-visible .ep-rname {
    color: var(--ss-olive);
  }

  /* ----- NOW · 2026 / +2027 roadmap lines (per ring + core) ----- */
  .ep-timeline {
    display: flex; flex-direction: column; gap: 3px;
    margin: 0 0 8px; padding-left: 25px; /* align under header text, past icon */
  }
  .ep-tl-row {
    display: flex; flex-wrap: wrap; align-items: center; gap: 5px;
    line-height: 1.3;
  }
  .ep-tl-tag {
    font-family: var(--font-mono);
    font-size: 9.5px; letter-spacing: 0.06em; text-transform: uppercase;
    font-weight: 600; flex: none;
  }
  .ep-tl-now .ep-tl-tag { color: var(--ep-flow); }
  .ep-tl-next .ep-tl-tag { color: var(--ep-txt3); opacity: 0.85; }
  .ep-tl-chip {
    font-family: var(--font-mono); font-size: 10px; line-height: 1;
    padding: 2.5px 6px; border-radius: var(--radius-sm);
    border: 1px solid var(--ep-bd);
    color: var(--ep-flow); white-space: nowrap;
  }
  .ep-tl-chip-next {
    color: var(--ep-txt2); border-style: dashed; opacity: 0.85;
  }

  /* ----- the living core ----- */
  .ep-core {
    border: 2px solid var(--ep-core);
    background: var(--ss-olive-soft);
    border-radius: var(--radius-lg);
    padding: 12px 14px 14px;
  }
  .ep-core-head {
    display: flex; align-items: center; gap: 8px;
    padding: 2px 0 8px; text-decoration: none; color: var(--fg-1);
  }
  .ep-core-name { font-size: 14px; font-weight: 600; }
  .ep-core-tag { font-size: 12px; color: var(--ep-core); }
  .ep-core-head:hover .ep-core-name, .ep-core-head:focus-visible .ep-core-name {
    color: var(--ss-olive);
  }

  .ep-flow {
    display: flex; align-items: center; justify-content: center;
    flex-wrap: wrap; gap: 2px; padding: 4px 0 2px;
  }
  .ep-step {
    text-decoration: none; padding: 4px 6px; border-radius: var(--radius-sm);
    transition: background-color var(--dur-base) var(--ease-standard);
  }
  .ep-step:hover, .ep-step:focus-visible { background: rgba(133,160,58,0.14); }
  .ep-step-tag {
    font-family: var(--font-mono); font-size: 11px; color: var(--ep-flow);
    white-space: nowrap;
  }
  .ep-arrow { flex: none; }
  .ep-arrow line { stroke: var(--ep-flow); stroke-width: 1.5; }
  .ep-arrow path { fill: var(--ep-flow); }

  /* animated dashed flow */
  .ep-arrow line {
    stroke-dasharray: 4 5;
    animation: ep-dash 1.1s linear infinite;
  }
  @keyframes ep-dash { to { stroke-dashoffset: -18; } }

  /* ----- severed path ----- */
  .ep-severed {
    display: flex; flex-direction: column; align-items: center; margin: 4px 0;
  }
  .ep-sev {
    stroke: var(--ep-sevcol); stroke-width: 1.6;
    stroke-dasharray: 5 6; animation: ep-dash 1.5s linear infinite;
  }
  .ep-fill-sev { fill: var(--ep-sevcol); }
  .ep-noegress {
    font-size: 12.5px; font-weight: 600; color: var(--ep-sevcol);
    margin-top: -4px;
  }
  .ep-public {
    display: block; text-align: center; margin: 2px auto 14px; width: fit-content;
    padding: 10px 16px; border-radius: var(--radius-md);
    border: 1px solid var(--ep-bd); background: var(--ep-surface);
    text-decoration: none; opacity: 0.72;
    transition: opacity var(--dur-base) var(--ease-standard),
                border-color var(--dur-base) var(--ease-standard);
  }
  .ep-public:hover, .ep-public:focus-visible { opacity: 1; border-color: var(--ep-sevcol); }
  .ep-public-title { font-size: 13px; font-weight: 600; color: var(--fg-1); }
  .ep-public-sub { font-size: 12px; color: var(--ep-txt2); }

  /* ----- legend ----- */
  .ep-legend {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 16px;
    font-size: 12.5px; color: var(--ep-txt2);
  }
  .ep-legend li { display: flex; align-items: center; gap: 7px; }
  .ep-lg { width: 13px; height: 13px; border-radius: 3px; display: inline-block; }
  .ep-lg-in { background: var(--ss-olive); }
  .ep-lg-out { background: var(--ss-zinc-300); }
  .dark .ep-lg-out { background: var(--ss-zinc-700); }
  .ep-lg-sev {
    width: 18px; height: 0; border: none; border-top: 2px dashed var(--ep-sevcol);
    border-radius: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .ep-arrow line, .ep-sev { animation: none; }
    .ep-dept, .ep-rhead, .ep-step, .ep-public { transition: none; }
  }
</style>
