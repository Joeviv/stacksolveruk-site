---
// File: src/components/sovereignty/RiskOverlay.astro
// "Built for 2026, ready for 2027" — the threats facing sovereign AI, tagged
// 2026 (now) or 2027 (next), each mapped to the layer of ours that handles it.
// Cards are real links to the risks page. Content lives in
// src/data/sovereignArchitecture.ts. EN-UK, sentence case.
import { RISKS } from "../../data/sovereignArchitecture";
---

<div class="ro-legend" aria-hidden="true">
  <span><span class="ro-dot ro-dot-now"></span>Now · 2026 priority</span>
  <span><span class="ro-dot ro-dot-next"></span>Next · 2027 horizon</span>
</div>

<ul class="ro-grid" role="list">
  {RISKS.map((r) => (
    <li class:list={["ro-card", { "ro-card-hl": r.quantumReady }]}>
      <a href={r.href} class="ro-link">
        <div class="ro-top">
          <span class:list={["ro-when", r.when === "now" ? "ro-now" : "ro-next"]}>
            <span class="ro-dot"></span>
            {r.when === "now" ? "2026" : "2027"}
          </span>
          {r.quantumReady && <span class="ro-badge">quantum-ready</span>}
        </div>
        <h3 class="ro-title">{r.title}</h3>
        <p class="ro-detail">{r.detail}</p>
        <div class="ro-answer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="ro-check">
            <path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z"/><path d="m9.5 12 1.8 1.8L15 10"/>
          </svg>
          <span>{r.answer}</span>
        </div>
        <div class="ro-layer">→ {r.layer}</div>
      </a>
    </li>
  ))}
</ul>

<style>
  .ro-legend {
    display: flex; flex-wrap: wrap; gap: 18px; margin-bottom: 18px;
    font-size: 13px; color: var(--fg-2);
  }
  .ro-legend > span { display: inline-flex; align-items: center; gap: 7px; }
  .ro-dot { width: 9px; height: 9px; border-radius: 9999px; display: inline-block; flex: none; }
  .ro-dot-now { background: var(--ss-olive); }
  .ro-dot-next { background: #d97706; }

  .ro-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .ro-card { display: flex; }
  .ro-link {
    display: flex; flex-direction: column; gap: 8px; width: 100%;
    text-decoration: none; color: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px 18px;
    transition: border-color var(--dur-base) var(--ease-standard),
                transform var(--dur-base) var(--ease-standard),
                box-shadow var(--dur-base) var(--ease-standard);
  }
  .ro-link:hover, .ro-link:focus-visible {
    border-color: var(--ss-olive);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .ro-card-hl .ro-link { border-color: var(--ss-olive); border-width: 2px; }

  .ro-top { display: flex; align-items: center; gap: 8px; }
  .ro-when {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--font-mono); font-size: 11px; font-weight: 500;
  }
  .ro-now { color: var(--ss-olive); }
  .ro-now .ro-dot { background: var(--ss-olive); }
  .ro-next { color: #d97706; }
  .ro-next .ro-dot { background: #d97706; }
  .ro-badge {
    margin-left: auto; font-size: 10.5px; font-weight: 600;
    color: var(--ss-olive); letter-spacing: 0.02em;
  }

  .ro-title { font-size: 15px; font-weight: 600; line-height: 1.3; margin: 0; color: var(--fg-1); }
  .ro-detail { font-size: 13px; line-height: 1.5; color: var(--fg-2); margin: 0; }
  .ro-answer {
    display: flex; align-items: flex-start; gap: 7px;
    font-size: 12.5px; color: var(--fg-2); line-height: 1.45;
    border-top: 1px solid var(--border); padding-top: 9px; margin-top: 2px;
  }
  .ro-check { color: var(--success); flex: none; margin-top: 1px; }
  .ro-layer { font-size: 12px; color: var(--fg-3); }
  .ro-link:hover .ro-title, .ro-link:focus-visible .ro-title { color: var(--ss-olive); }

  @media (prefers-reduced-motion: reduce) {
    .ro-link { transition: none; }
    .ro-link:hover, .ro-link:focus-visible { transform: none; }
  }
</style>
