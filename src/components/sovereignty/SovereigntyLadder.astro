---
// File: src/components/sovereignty/SovereigntyLadder.astro
// The four readiness levels as an ascending staircase: taller = more sovereign.
// Our own wording and visual; theme-aware via Tailwind dark: utilities. EN-UK.
const levels = [
  {
    n: "0", name: "Dependent", x: 60, top: 230, h: 120,
    c1: "closed foreign AI,", c2: "risks unmeasured",
    box: "fill-white dark:fill-zinc-900 stroke-zinc-300 dark:stroke-zinc-700",
    num: "fill-zinc-400 dark:fill-zinc-600",
  },
  {
    n: "1", name: "Prepared", x: 280, top: 180, h: 170,
    c1: "risks mapped,", c2: "still on trust",
    box: "fill-white dark:fill-zinc-900 stroke-olive-300 dark:stroke-olive-800",
    num: "fill-olive-500 dark:fill-olive-400",
  },
  {
    n: "2", name: "Independent", x: 500, top: 130, h: 220,
    c1: "risks actively", c2: "mitigated",
    box: "fill-white dark:fill-zinc-900 stroke-olive-400 dark:stroke-olive-600",
    num: "fill-olive-500 dark:fill-olive-400",
  },
  {
    n: "3", name: "Sovereign", x: 720, top: 80, h: 270,
    c1: "self-hosted, open-", c2: "weight, controlled",
    box: "fill-olive-50 dark:fill-olive-500/10 stroke-olive-500 dark:stroke-olive-400",
    num: "fill-olive-600 dark:fill-olive-300",
  },
];
const W = 180;
---

<svg viewBox="0 0 920 410" width="100%" role="img" class="block" xmlns="http://www.w3.org/2000/svg">
  <title>AI sovereignty readiness — four levels</title>
  <desc>
    An ascending staircase of four levels: 0 dependent, 1 prepared, 2 independent, 3 sovereign.
    Each step is taller than the last; the tallest, sovereign, means self-hosted, open-weight AI on
    infrastructure you control with all five sovereignty risks managed.
  </desc>

  <!-- Ascent guide through the step tops -->
  <polyline points="150,230 370,180 590,130 810,80"
            class="stroke-olive-500/40 dark:stroke-olive-400/30" stroke-width="2" stroke-dasharray="2 6" fill="none" />

  <!-- Steps -->
  {levels.map((l) => (
    <g>
      <rect x={l.x} y={l.top} width={W} height={l.h} rx={14} class={l.box} stroke-width="2" />
      <text x={l.x + 22} y={l.top + 56} class={`${l.num} font-sans`} font-size="40" font-weight="700">{l.n}</text>
      <text x={l.x + 22} y={306} class="fill-zinc-900 dark:fill-white font-sans" font-size="21" font-weight="600">{l.name}</text>
      <text x={l.x + 22} y={328} class="fill-zinc-500 dark:fill-zinc-400 font-sans" font-size="13.5">{l.c1}</text>
      <text x={l.x + 22} y={344} class="fill-zinc-500 dark:fill-zinc-400 font-sans" font-size="13.5">{l.c2}</text>
    </g>
  ))}

  <!-- Axis -->
  <line x1="60" y1="368" x2="900" y2="368" class="stroke-zinc-200 dark:stroke-zinc-800" stroke-width="1.5" />
  <text x="60" y="392" class="fill-zinc-500 dark:fill-zinc-500 font-mono" font-size="12.5" letter-spacing="0.5">more dependent</text>
  <text x="900" y="392" text-anchor="end" class="fill-olive-600 dark:fill-olive-400 font-mono" font-size="12.5" letter-spacing="0.5">more sovereign →</text>
</svg>
