---
// File: src/pages/risks.astro
// The risks page reached from the home risk overlay. Built for 2026, ready for
// 2027. Each risk has an anchor that the home cards deep-link to. EN-UK.
// Verified content: Biblioteca/Sovereign_AI/02_Riesgos_2026_2027_y_ForwardLook.md
import Layout from "../layouts/Layout.astro";
import RiskOverlay from "../components/sovereignty/RiskOverlay.astro";

const seoTitle = "Sovereign AI risks 2026 → 2027 | Fox&Stack";
const seoDescription =
  "The threats facing sovereign AI in 2026 and on the 2027 horizon — prompt injection, model poisoning, shadow AI, agentic risk, deepfakes, regulation and quantum — each mapped to the Fox&Stack layer that neutralises it. Quantum-ready by design.";

const detail = [
  {
    id: "prompt-injection",
    when: "2026",
    title: "Prompt injection",
    body: "The number-one risk in the OWASP Top 10 for LLM applications. Malicious instructions are hidden inside the documents, emails and web pages a model reads, overriding its intent. Indirect injection — through the content a RAG system retrieves — is the most dangerous variant. We neutralise it at the guardrails layer with input and output filtering and a strict separation of instruction from data.",
    layer: "L3 · Guardrails",
  },
  {
    id: "poisoning",
    when: "2026",
    title: "Model & data poisoning",
    body: "Tampered training, fine-tuning or retrieval data quietly corrupts a model's behaviour. We validate data provenance, keep data lineage, and run pre-deployment evaluations so a poisoned input does not become a trusted answer.",
    layer: "L2 · Model (+ L4 governance)",
  },
  {
    id: "supply-chain",
    when: "2026",
    title: "Model supply chain",
    body: "Public model hubs host millions of models, and malicious ones are rising sharply. Supply chain is now the third-highest OWASP LLM risk. We use vetted, local, provenance-tracked models, prefer the safetensors format that cannot execute code on load, and verify signatures where available.",
    layer: "L2 · Model",
  },
  {
    id: "agentic",
    when: "2027",
    title: "Agentic AI · excessive agency",
    body: "When a model stops generating text and starts acting — calling tools, querying databases, running code — the blast radius of a single injection grows. We scope permissions to least privilege, keep a human in the loop for irreversible actions, and monitor agent behaviour.",
    layer: "L3 + L5 · Guardrails / Ops",
  },
  {
    id: "shadow-ai",
    when: "2026",
    title: "Shadow AI · data leakage",
    body: "Staff pasting confidential data into public AI tools is the core sovereignty problem. Sovereign AI solves it by architecture: inference runs locally, so the data never leaves your perimeter in the first place.",
    layer: "L2 + L1 · Local",
  },
  {
    id: "deepfakes",
    when: "2026",
    title: "Deepfakes & impersonation",
    body: "Synthetic voice and video drive fraud and social engineering, including fraudulent payment and access requests. The defence is process plus monitoring: verification through an alternate channel and a keyword for unusual requests.",
    layer: "L5 + L3 · Ops",
  },
  {
    id: "regulatory",
    when: "2027",
    title: "Regulatory · EU AI Act",
    body: "High-risk obligations under the EU AI Act now land in December 2027, and a firm selling into the EU is in scope even if it operates from the UK. The UK itself stays pro-innovation. We build ISO 42001 governance and audit trails in from the start, so you are ready for the deadline without a costly retrofit.",
    layer: "L4 · Governance",
  },
  {
    id: "quantum",
    when: "2027",
    title: "Quantum · harvest now, decrypt later",
    body: "Adversaries capture encrypted data today and archive it to decrypt once quantum matures. Long-lived sovereign data — health, legal, IP, government — is still valuable for decades, so it is exposed now. We follow the NCSC's UK migration roadmap: crypto inventory first, then hybrid post-quantum cryptography (NIST ML-KEM / ML-DSA). Quantum-ready by design, not as an afterthought.",
    layer: "L1 + L4 · Crypto",
  },
];
---

<Layout title={seoTitle} description={seoDescription} type="article">
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 pt-20 pb-12 lg:pt-24">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-olive-600 dark:text-olive-400 mb-8 hover:gap-3 transition-all">
        <span aria-hidden>←</span> Back to the perimeter
      </a>
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Credibility · quantum-ready</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white mb-5">
        Built for 2026, ready for 2027.
      </h1>
      <p class="text-lg md:text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-2xl">
        The threats facing sovereign AI — and the layer of ours that handles each.
        No alarmism: just what matters now, what is coming next, and how the
        architecture answers it.
      </p>
    </div>
  </section>

  <section class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
      <RiskOverlay />
    </div>
  </section>

  <section class="bg-white dark:bg-black">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 space-y-12">
      {detail.map((r) => (
        <article id={r.id} class="scroll-mt-24 border-b border-zinc-200 dark:border-zinc-800 pb-12 last:border-0">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-olive-500/10 text-olive-700 dark:text-olive-300 border border-olive-500/30">{r.when}</span>
            <span class="text-xs font-mono text-zinc-500 dark:text-zinc-500">{r.layer}</span>
          </div>
          <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white mb-3">{r.title}</h2>
          <p class="text-zinc-700 dark:text-zinc-300 leading-relaxed">{r.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
        Ready for what is coming.
      </h2>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8 max-w-2xl mx-auto">
        Tell us where your data sits and which regulators you answer to. We will show you,
        in our lab, how the architecture holds.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
        Book a lab demo <span aria-hidden>→</span>
      </a>
    </div>
  </section>
</Layout>
