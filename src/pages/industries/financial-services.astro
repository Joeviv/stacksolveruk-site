---
// File: src/pages/industries/financial-services.astro
// Vertical page reached from the home perimeter diagram's "By sector" strip.
// Sovereign AI framed for financial services. EN-UK, sentence case. Claims are
// about our architecture/approach — "aligned"/"mapped"/"ready", not unproven
// certifications.
import LayerPage from "../../components/sovereignty/LayerPage.astro";

const points = [
  {
    title: "Lineage and provenance",
    body: "Every answer traces back to the data and the model that produced it — the explainability you need for credit, KYC and customer-facing decisions.",
  },
  {
    title: "Operational resilience",
    body: "Running AI in your own perimeter removes the single-vendor dependency on a foreign API — directly relevant to DORA third-party risk and FCA/PRA operational resilience.",
  },
  {
    title: "Governed and auditable",
    body: "Human oversight, access control and an audit layer, with an AI risk register mapped to ISO 42001 — governance you can put in front of a regulator.",
  },
  {
    title: "Ready for what is next",
    body: "Continuous model assurance and quantum-ready encryption, so the deployment holds up as obligations tighten through 2027 and beyond.",
  },
];

const standards = [
  "ISO 27001",
  "ISO 42001",
  "DORA (aligned)",
  "FCA / PRA op-resilience",
  "Cyber Essentials",
];
---

<LayerPage
  eyebrow="For your sector · Financial services"
  layerTag="FCA · lineage · resilience"
  title="Sovereign AI for financial services"
  lede="The regulatory bar is high and rising — FCA, PRA and DORA. We run AI inside your perimeter with the data lineage, provenance and operational resilience your regulators and your board expect."
  seoTitle="Sovereign AI for financial services — Fox&Stack"
  seoDescription="On-premise AI for financial services: data lineage and provenance, operational resilience aligned to DORA and FCA/PRA, and ISO 42001 governance — no dependency on a foreign AI API."
  points={points}
  standards={standards}
>
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Why it matters here</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6">
        Don't make a foreign API a single point of failure.
      </h2>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          Operational resilience means not depending on one external provider you cannot govern.
          Running AI inside your own perimeter removes that dependency — directly relevant to
          DORA third-party risk and FCA/PRA operational resilience.
        </p>
        <p>
          Open weights mean you can change the model without re-platforming; lineage and
          provenance mean every decision is explainable to a regulator. And because today's
          encryption is not tomorrow's, the perimeter is built quantum-ready by design.
        </p>
      </div>
    </div>
  </section>
</LayerPage>
