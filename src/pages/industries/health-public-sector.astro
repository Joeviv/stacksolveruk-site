---
// File: src/pages/industries/health-public-sector.astro
// Vertical page reached from the home perimeter diagram's "By sector" strip.
// Sovereign AI framed for health & the public sector. EN-UK, sentence case.
// Claims are about our architecture/approach — "built toward" / "aligned",
// never asserting a certification we do not yet hold.
import LayerPage from "../../components/sovereignty/LayerPage.astro";

const points = [
  {
    title: "Patient and citizen data stays in the UK",
    body: "Open-weight models run on infrastructure you control, in-country. No record, prompt or document is sent to a foreign AI provider — there is no data egress to cross.",
  },
  {
    title: "Procurement-ready foundations",
    body: "Cyber Essentials and ISO 27001 underpin the perimeter, and the build is mapped toward the assurance public buyers expect — including the NHS Data Security and Protection Toolkit (DSPT) and DTAC alignment for digital tools.",
  },
  {
    title: "Governed, auditable use",
    body: "Every interaction is access-controlled and audit-logged, with human oversight and an AI risk register — the governance an Information Governance team can sign off and defend.",
  },
  {
    title: "Built for what is coming",
    body: "Quantum-ready encryption and EU AI Act high-risk readiness, so a deployment that is safe today does not become a liability tomorrow.",
  },
];

const standards = [
  "Cyber Essentials",
  "ISO 27001",
  "ISO 42001",
  "NHS DSPT (mapped)",
  "DTAC (aligned)",
  "UK GDPR",
];
---

<LayerPage
  eyebrow="For your sector · Health & public sector"
  layerTag="UK residency · zero egress"
  title="Sovereign AI for health and the public sector"
  lede="Patient and citizen data is the most sensitive in the country, and it must never leave your jurisdiction. We run AI inside your perimeter, on UK-resident infrastructure, with nothing egressed to a foreign cloud."
  seoTitle="Sovereign AI for health & the public sector — Fox&Stack"
  seoDescription="On-premise, UK-resident AI for health and the public sector: patient and citizen data never leaves your perimeter, with Cyber Essentials, ISO 27001/42001 foundations and DSPT/DTAC alignment."
  points={points}
  standards={standards}
>
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Why it matters here</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6">
        Public bodies should answer to the public — not to a vendor.
      </h2>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          Sovereignty is not only about where data sits — it is about who sets the rules.
          When patient and citizen records run on a platform you do not control, those rules
          are set somewhere else, and changing your mind later can mean discovering you
          cannot get your data back.
        </p>
        <p>
          We keep the data, the models and the decisions inside your perimeter, on UK-resident
          infrastructure you control, with governance your Information Governance team owns and
          can defend. Your organisation sets the rules — not a supplier, and not a foreign
          jurisdiction.
        </p>
      </div>
    </div>
  </section>
</LayerPage>
