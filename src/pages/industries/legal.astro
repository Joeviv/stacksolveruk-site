---
// File: src/pages/industries/legal.astro
// Vertical page reached from the home perimeter diagram's "By sector" strip.
// Sovereign AI framed for law firms. EN-UK, sentence case. Claims are about
// our architecture/approach, not unproven certifications.
import LayerPage from "../../components/sovereignty/LayerPage.astro";

const points = [
  {
    title: "Confidential by construction",
    body: "Matter documents are processed inside your perimeter, on infrastructure you control. Nothing is sent to a public AI service, and nothing is used to train an external model.",
  },
  {
    title: "Safe AI for junior fee-earners",
    body: "PII masking and prompt-injection defence let lawyers use AI on real documents with bounded, auditable behaviour — the assurance a risk partner needs before rollout.",
  },
  {
    title: "Defensible to clients and regulators",
    body: "Access control and an audit layer record every interaction, giving your General Counsel and compliance team the evidence trail they will be asked for.",
  },
  {
    title: "Your know-how stays yours",
    body: "Open-weight models, run in-house, so privileged matters, precedents and firm IP never leave your control or feed someone else's product.",
  },
];

const standards = [
  "Legal professional privilege",
  "Cyber Essentials",
  "ISO 27001",
  "ISO 42001",
  "UK GDPR",
];
---

<LayerPage
  eyebrow="For your sector · Legal"
  layerTag="privilege · confidentiality"
  title="Sovereign AI for law firms"
  lede="Privilege and client confidentiality are absolute. We give your lawyers AI that never exposes a confidential matter to a public model — it runs inside your perimeter, with nothing leaving and nothing training someone else's model."
  seoTitle="Sovereign AI for law firms — Fox&Stack"
  seoDescription="On-premise AI for law firms: confidential matters processed inside your perimeter, with PII masking, prompt-injection defence and a full audit trail. Privilege preserved, IP retained."
  points={points}
  standards={standards}
>
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Why it matters here</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6">
        If you cannot get your data back, you never owned it.
      </h2>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          The risk with outside AI is not only a leak today — it is dependency. Platforms and
          contracts can be structured so that leaving means leaving your data behind. For a firm
          that holds privileged matters, that is not a risk you can accept.
        </p>
        <p>
          Inside your perimeter, on open-weight models you run yourself, there is nothing to
          claw back and nothing training someone else's product. Privilege is preserved by
          architecture, not by a clause in a supplier's terms.
        </p>
      </div>
    </div>
  </section>
</LayerPage>
