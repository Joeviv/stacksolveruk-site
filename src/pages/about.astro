---
// File: src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About | Stacksolver UK"
  description="Stacksolver UK Limited — a Brighton-based technology consultancy. Claris FileMaker Partner, GRC and ERP specialists serving the United Kingdom, Europe and the United States."
>
  <section class="min-h-screen flex items-center bg-white dark:bg-black">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-24">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">About</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        A British technology consultancy<br />for regulated industries.
      </h1>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          Stacksolver UK Limited is a Brighton-based consultancy. We design and deliver bespoke
          enterprise systems where governance, risk and compliance are not bolted on — they are built in.
        </p>
        <p>
          Our practice combines an <strong>official Claris FileMaker Partner</strong> background with deep
          experience in ISO 27001 and ISO 42001 implementation, sovereign AI deployments, and
          Apple Business Manager rollouts.
        </p>
        <p>
          We work primarily with <strong>fiduciary services, corporate services, legal, financial services
          and AI-sensitive sectors</strong> across the United Kingdom, Europe and the United States.
        </p>
        <p class="text-zinc-500 dark:text-zinc-500 italic pt-6 border-t border-zinc-200 dark:border-zinc-800">
          A more detailed company profile, leadership and credentials section is being prepared.
          For commercial enquiries please email <a href="mailto:office@stacksolveruk.com" class="text-olive-600 dark:text-olive-400 hover:underline">office@stacksolveruk.com</a>.
        </p>
      </div>
      <div class="mt-12 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Contact us <span aria-hidden>→</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Back home
        </a>
      </div>
    </div>
  </section>
</Layout>
