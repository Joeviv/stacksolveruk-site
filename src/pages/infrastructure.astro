---
// File: src/pages/infrastructure.astro
// Ring page — Sovereign infrastructure (L1). Where it runs, where data stays, crypto.
// Verified content: Biblioteca/Sovereign_AI/01_Arquitectura_Referencia_Capas.md (L1)
// and 02_Riesgos_2026_2027_y_ForwardLook.md (quantum / HNDL → L1+L4). EN-UK, sentence case.
import LayerPage from "../components/sovereignty/LayerPage.astro";

const points = [
  {
    title: "A spectrum, from a single node to air-gapped",
    body: "Start on one Apple Silicon node — cheap, quiet and robust — then grow to an on-premise server, and to a fully air-gapped server with no cable to the internet for the most sensitive work. The same architecture, sized to you.",
  },
  {
    title: "Data residency in the UK",
    body: "Your data stays in country, on hardware you control. No copies in an opaque region, no quiet replication to a provider's other estate — residency you can put in writing for a regulator.",
  },
  {
    title: "No egress to opaque third parties",
    body: "The perimeter is the point: the data the model touches does not leave it. Network controls enforce it, so sovereignty is a property of the architecture, not a promise in a contract.",
  },
  {
    title: "Encryption at rest and in transit",
    body: "Strong encryption on stored data and on every link inside the perimeter — the floor that everything above it is built on.",
  },
  {
    title: "Quantum-ready by design",
    body: "Long-lived sovereign data — health, legal, IP, government — is still valuable for decades, so data captured today is exposed to tomorrow's quantum decryption. We follow the NCSC's UK roadmap: a crypto inventory first, then hybrid post-quantum cryptography (NIST ML-KEM / ML-DSA).",
  },
  {
    title: "The model comes to your data",
    body: "Sovereign by architecture means the inference runs where the data already lives. There is no upload, no external API call — the foundation that makes shadow AI impossible rather than merely discouraged.",
  },
];

const standards = [
  "On-premise",
  "Air-gapped option",
  "UK data residency",
  "No egress",
  "Encryption at rest & in transit",
  "Post-quantum (ML-KEM / ML-DSA)",
  "NCSC PQC roadmap",
  "Apple Silicon → server",
];

const seoTitle = "Sovereign infrastructure — where it runs, where your data stays | Fox&Stack";
const seoDescription =
  "The infrastructure ring of Fox&Stack's Sovereign AI (L1): on-premise or air-gapped hardware you control, UK data residency, no egress, encryption at rest and in transit, and quantum-ready post-quantum cryptography on the NCSC roadmap.";
---

<LayerPage
  eyebrow="Ring · where it runs"
  layerTag="L1 · Sovereign infrastructure"
  title="Infrastructure is where your data simply stays."
  lede="The foundation of the perimeter and the asset everything else protects. From a single Apple Silicon node to an on-premise or air-gapped server, with data residency in the UK, no egress to opaque third parties, and encryption built for the quantum era."
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  points={points}
  standards={standards}
>
  <!-- Why it is the foundation -->
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Why it is the foundation</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6">
        Sovereign by architecture starts with the hardware.
      </h2>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          Every other layer assumes one thing: that the data and the model live somewhere you
          own. Take that away — put the model behind someone else's API — and guardrails,
          governance and certificates are protecting a copy you no longer hold. Infrastructure
          is the layer that makes the rest <strong>true</strong>.
        </p>
        <p>
          It is also the layer that future-proofs the data. The same place your data sits today
          is where it will sit for the decades it stays sensitive — so we treat the crypto as a
          long horizon, not a checkbox, and align it to the NCSC's published migration roadmap
          rather than inventing our own.
        </p>
      </div>
    </div>
  </section>

  <!-- The maturity ladder -->
  <section class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Sized to you</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Where you enter is up to you.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-2">Entry</div>
          <div class="font-semibold text-zinc-900 dark:text-white mb-1">A single node</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400">Apple Silicon — a controlled local gateway for a smaller team.</div>
        </div>
        <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-2">Mid</div>
          <div class="font-semibold text-zinc-900 dark:text-white mb-1">On-premise</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400">Local inference, residency guaranteed, sensitive data never leaves.</div>
        </div>
        <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-2">Maximum</div>
          <div class="font-semibold text-zinc-900 dark:text-white mb-1">Air-gapped</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400">No cable to the internet — sovereignty at its most absolute.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- The rings around it -->
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">The rings above it</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Each ring has its own page.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/security" class="group block p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Security & guardrails</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">the safety wall</div>
        </a>
        <a href="/governance" class="group block p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Governance & GRC</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">how it is controlled</div>
        </a>
        <a href="/compliance" class="group block p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Compliance</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">the certified boundary</div>
        </a>
      </div>
    </div>
  </section>
</LayerPage>
