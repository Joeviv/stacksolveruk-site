---
// File: src/pages/industries.astro
import Layout from '../layouts/Layout.astro';

const industries = [
  {
    id: 'tech',
    title: 'Technology',
    summary:
      'Software companies, data platforms, AI vendors and infrastructure providers — where security and AI governance are existential, not optional.',
    pains: [
      'SOC 2 Type II readiness for US enterprise sales',
      'ISO 27001 certification for European procurement',
      'AI Governance under the EU AI Act and UK AI White Paper',
      'AI Red Teaming for production LLM applications',
      'Supplier security questionnaires that take weeks to answer',
    ],
    services: [
      { label: 'SOC 2 readiness', href: '/services/iso-compliance/soc-2' },
      { label: 'ISO 27001', href: '/services/iso-compliance/iso-27001' },
      { label: 'AI Governance (ISO 42001)', href: '/services/ai/ai-governance-iso-42001' },
      { label: 'AI Red Teaming', href: '/services/ai-security/ai-red-teaming' },
      { label: 'TPRM programme', href: '/services/risk-resilience/tprm-programme' },
    ],
  },
  {
    id: 'professional-services',
    title: 'Professional Services',
    summary:
      'Law firms, accountancy practices, management consultancies and advisory boutiques — where client confidentiality and operational discipline are core to the brand.',
    pains: [
      'Cyber Essentials Plus for client onboarding',
      'GDPR compliance and DPO function',
      'Vendor risk programme to satisfy insurer and client questionnaires',
      'Sovereign AI for confidential document workflows',
      'Incident response retainer with a defined SLA',
    ],
    services: [
      { label: 'Cyber Essentials Plus', href: '/services/cyber/cyber-essentials-plus' },
      { label: 'DPO-as-a-Service', href: '/services/grc/dpo-as-service' },
      { label: 'TPRM programme', href: '/services/risk-resilience/tprm-programme' },
      { label: 'Sovereign RAG', href: '/services/ai/sovereign-rag' },
      { label: 'Incident Response', href: '/services/cyber/incident-response' },
    ],
  },
  {
    id: 'financial-services',
    title: 'Financial Services',
    summary:
      'Banks, payment institutions, e-money issuers, insurers and asset managers — where the regulatory bar is high and rising fast under DORA, the FCA and the PRA.',
    pains: [
      'DORA readiness and ICT Third-Party Provider register',
      'Threat-Led Penetration Testing (TLPT) under TIBER-EU',
      'UK Operational Resilience under PRA SS1/21 and FCA PS21/3',
      'Critical service mapping and impact tolerance setting',
      'AI governance for credit, KYC and customer-facing systems',
    ],
    services: [
      { label: 'DORA readiness', href: '/services/risk-resilience/dora-readiness' },
      { label: 'TLPT testing', href: '/services/risk-resilience/tlpt-testing' },
      { label: 'UK Operational Resilience', href: '/services/risk-resilience/operational-resilience-uk' },
      { label: 'AI Governance (ISO 42001)', href: '/services/ai/ai-governance-iso-42001' },
      { label: 'vCISO retainer', href: '/services/cyber/vciso-retainer' },
    ],
  },
  {
    id: 'healthcare',
    title: 'Healthcare &amp; Life Sciences',
    summary:
      'Hospitals, clinics, life sciences firms and digital health platforms — where patient data and clinical AI carry the highest regulatory and reputational stakes.',
    pains: [
      'NHS Data Security and Protection Toolkit (DSPT)',
      'ISO 27001 + ISO 27701 (privacy extension)',
      'GDPR compliance for special category data',
      'NIS2 obligations for in-scope healthcare entities',
      'AI clinical decision support governance under EU AI Act Annex III',
    ],
    services: [
      { label: 'ISO 27001 + 27701', href: '/services/iso-compliance/iso-27701-privacy' },
      { label: 'GDPR / UK GDPR', href: '/services/iso-compliance/gdpr-uk-gdpr' },
      { label: 'NIS2 readiness', href: '/services/risk-resilience/nis2-readiness' },
      { label: 'AI Governance (ISO 42001)', href: '/services/ai/ai-governance-iso-42001' },
      { label: 'DPO-as-a-Service', href: '/services/grc/dpo-as-service' },
    ],
  },
  {
    id: 'corporate-services',
    title: 'Corporate Services &amp; Fund Administration',
    summary:
      'Fiduciary services, fund administrators, trust companies and corporate service providers — where audit trails, multi-jurisdictional compliance and client confidentiality are non-negotiable.',
    pains: [
      'Sovereign AI for confidential document workflows across jurisdictions',
      'Procurement + AI for vendor scoring and risk monitoring',
      'ISAE 3402 / ISO 27001 alignment',
      'Cross-border data transfers under UK GDPR and EU GDPR',
      'Local AI deployments in client-required jurisdictions',
    ],
    services: [
      { label: 'Sovereign RAG', href: '/services/ai/sovereign-rag' },
      { label: 'Procurement + AI', href: '/services/areas-ai/procurement-ai' },
      { label: 'ISO 27001', href: '/services/iso-compliance/iso-27001' },
      { label: 'GDPR / UK GDPR', href: '/services/iso-compliance/gdpr-uk-gdpr' },
      { label: 'Local AI Stack', href: '/services/local-ai/lean-tier-mac-studio' },
    ],
  },
];
---

<Layout
  title="Industries | Fox&Stack"
  description="Cyber Security, AI Engineering and Compliance for Technology, Professional Services, Financial Services, Healthcare and Corporate Services in the UK, EU and US."
>
  <!-- Hero -->
  <section class="bg-white dark:bg-black">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 pt-24 pb-16">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">Industries</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Built for regulated industries.
      </h1>
      <p class="text-lg md:text-xl text-zinc-700 dark:text-zinc-300 leading-relaxed">
        We work with mid-market organisations across five sectors where audit trails, regulatory pressure
        and data sovereignty are not optional. Each industry brings its own pain points — and its own
        bar for what "compliant" really means.
      </p>
    </div>
  </section>

  <!-- Industries -->
  {industries.map((ind, idx) => (
    <section
      id={ind.id}
      class={(idx % 2 === 0 ? 'bg-zinc-50 dark:bg-zinc-950' : 'bg-white dark:bg-black') + ' border-t border-zinc-200 dark:border-zinc-800'}
    >
      <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-3">
          0{idx + 1}
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6" set:html={ind.title}></h2>
        <p class="text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed mb-10 max-w-3xl">
          {ind.summary}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div>
            <h3 class="text-sm font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
              Common pain points
            </h3>
            <ul class="space-y-3">
              {ind.pains.map((pain) => (
                <li class="flex gap-3 text-zinc-700 dark:text-zinc-300 leading-relaxed">
                  <span class="text-olive-500 flex-shrink-0">—</span>
                  <span>{pain}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
              Services we deliver here
            </h3>
            <ul class="space-y-2">
              {ind.services.map((svc) => (
                <li>
                  <a
                    href={svc.href}
                    class="inline-flex items-center gap-2 text-zinc-900 dark:text-white hover:text-olive-600 dark:hover:text-olive-400 transition-colors group"
                  >
                    <span class="border-b border-zinc-300 dark:border-zinc-700 group-hover:border-olive-500 transition-colors">{svc.label}</span>
                    <span aria-hidden class="text-olive-500">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
        Don't see your industry?
      </h2>
      <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-8 max-w-2xl mx-auto">
        We work with any mid-market organisation that takes Cyber, AI and Compliance seriously.
        Tell us about your context — we will tell you honestly whether we are the right fit.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Contact us <span aria-hidden>→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
