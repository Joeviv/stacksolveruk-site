---
// File: src/pages/fox4ndstack.astro
// CONFIDENTIAL — internal working document. Private strategy one-pager.
// Not part of the public site: no public navbar/footer, noindex, excluded from
// sitemap and robots. Do not link from any menu.
import "../styles/global.css";

const meetingDate = "13 June 2026";
---

<!doctype html>
<html lang="en-GB" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <title>Fox &amp; Fifth × StackSolver UK — Internal Working Document</title>
    <meta name="description" content="Confidential internal working document." />
  </head>
  <body
    class="bg-white text-zinc-900 dark:bg-black dark:text-zinc-50 font-sans min-h-screen overflow-x-hidden antialiased"
  >
    <!-- ── 0. Private header (minimal, no public nav) ───────────────────── -->
    <header
      class="sticky top-0 z-50 border-b border-zinc-200/80 dark:border-zinc-800/80 bg-white/80 dark:bg-black/80 backdrop-blur-md"
    >
      <div
        class="max-w-5xl mx-auto px-6 lg:px-8 py-3 flex flex-wrap items-center justify-between gap-3"
      >
        <span class="font-semibold tracking-tight text-zinc-900 dark:text-white">
          Fox &amp; Fifth <span class="text-olive-600 dark:text-olive-400">×</span> StackSolver UK
        </span>
        <span
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-[11px] font-mono uppercase tracking-widest border border-danger/40 text-[var(--danger)] bg-[var(--danger-soft)]"
          style="--danger:#be185d;"
        >
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--danger)]" style="--danger:#be185d;"></span>
          Confidential · Internal Working Document
        </span>
      </div>
    </header>

    <main class="w-full">
      <!-- ── 1. Hero ───────────────────────────────────────────────────── -->
      <section class="bg-white dark:bg-black">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 pt-16 pb-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">
            Consultancy · Cyber Security · Technology
          </p>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white leading-[1.05] mb-7 max-w-4xl">
            One team. The consultancy, the cyber and the technology to deliver both.
          </h1>
          <p class="text-lg md:text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl">
            How Fox &amp; Fifth and StackSolver UK come together as one team to win CLIENT_X — and the
            contracts behind it — by giving the client continuity, cyber credibility and real technology depth.
          </p>
          <p class="mt-8 text-sm text-zinc-500 dark:text-zinc-500">
            Prepared for the partner meeting — winning and growing the CLIENT_X engagement · {meetingDate}
          </p>
        </div>
      </section>

      <!-- ── 2. The opportunity ────────────────────────────────────────── -->
      <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            The opportunity — CLIENT_X
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6 max-w-3xl">
            The incumbent is winding down. The client needs continuity.
          </h2>
          <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl mb-10">
            The incumbent supplier is winding down. CLIENT_X needs continuity — without losing the people,
            the cyber assurance or the momentum.
          </p>

          <div class="grid gap-5 md:grid-cols-3">
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Continuity of delivery</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                The same trusted people, no disruption as the incumbent exits.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">A cyber-credible partner</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Security expertise the board and auditors can rely on.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Technology depth to modernise</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Cloud, AI and ERP to move off legacy systems.
              </p>
            </div>
          </div>

          <div class="mt-8 rounded-xl border-l-4 border-olive-500 bg-olive-500/5 dark:bg-olive-500/10 px-6 py-5">
            <p class="text-base text-zinc-700 dark:text-zinc-200 leading-relaxed">
              A clean, organic continuity play: the client keeps what works, and gains the technology
              muscle the incumbent never had.
            </p>
          </div>
        </div>
      </section>

      <!-- ── 3. The assets on the table (TABLE) ────────────────────────── -->
      <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            The deal
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6 max-w-3xl">
            The assets on the table.
          </h2>
          <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl mb-10">
            The engagement is already live and already growing.
          </p>

          <div class="overflow-x-auto rounded-xl border border-zinc-200 dark:border-zinc-800">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-zinc-50 dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800">
                  <th class="px-5 py-3 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Status</th>
                  <th class="px-5 py-3 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Assets</th>
                  <th class="px-5 py-3 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Note</th>
                </tr>
              </thead>
              <tbody class="text-sm">
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                  <td class="px-5 py-4 font-semibold text-zinc-900 dark:text-white whitespace-nowrap">In contract today</td>
                  <td class="px-5 py-4 font-semibold text-olive-700 dark:text-olive-400 whitespace-nowrap">3 assets</td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">Currently delivered through the incumbent supplier.</td>
                </tr>
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                  <td class="px-5 py-4 font-semibold text-zinc-900 dark:text-white whitespace-nowrap">Approved to add</td>
                  <td class="px-5 py-4 font-semibold text-olive-700 dark:text-olive-400 whitespace-nowrap">+2 assets</td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">Already signed off by CLIENT_X — ready to mobilise.</td>
                </tr>
                <tr class="bg-zinc-50/60 dark:bg-zinc-900/40">
                  <td class="px-5 py-4 font-semibold text-zinc-900 dark:text-white whitespace-nowrap">Target</td>
                  <td class="px-5 py-4 font-bold text-zinc-900 dark:text-white whitespace-nowrap">5 assets</td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-400">Delivered under Fox &amp; Fifth as the new prime.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p class="mt-8 text-base text-zinc-700 dark:text-zinc-200 leading-relaxed max-w-3xl">
            The work, the people and the approval already exist. What we are changing is who holds the
            contract — <strong class="text-zinc-900 dark:text-white">Fox &amp; Fifth as prime</strong>, with
            StackSolver UK as the technology and cyber engine behind delivery.
          </p>
        </div>
      </section>

      <!-- ── 4. Who we are — one team ──────────────────────────────────── -->
      <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            Who we are — one team
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-10 max-w-3xl">
            Two firms. One team.
          </h2>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-7">
              <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">
                Fox &amp; Fifth — Consultancy &amp; establishment
              </h3>
              <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Client relationships, partnerships, procurement and project delivery. The trusted front
                door and the contracting prime.
              </p>
            </div>
            <div class="rounded-xl border border-olive-500/40 bg-olive-500/5 dark:bg-olive-500/10 p-7">
              <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">
                StackSolver UK — Technology, Cyber &amp; AI
              </h3>
              <p class="text-zinc-600 dark:text-zinc-300 leading-relaxed">
                Cyber security, cloud, AI and enterprise systems (ERP / Claris FileMaker). The muscle that
                turns advice into systems that ship.
              </p>
            </div>
          </div>

          <p class="mt-10 text-xl md:text-2xl font-medium tracking-tight text-zinc-900 dark:text-white text-center max-w-3xl mx-auto leading-snug">
            &ldquo;A package nobody could refuse — the technology and the establishment, as one team.&rdquo;
          </p>
        </div>
      </section>

      <!-- ── 4b. Our edge ──────────────────────────────────────────────── -->
      <section class="bg-olive-500/5 dark:bg-olive-500/10 border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            Our edge
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6 max-w-3xl">
            We start with momentum, not from a standing start.
          </h2>
          <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl mb-10">
            This is not a cold start. Our team brings deep, first-hand knowledge of how engagements like
            CLIENT_X&rsquo;s are actually run — the operating rhythm, the delivery model and what good looks
            like — together with an established network of vetted cyber specialists and subcontractors who can
            be mobilised at pace. Where others would spend months building the relationships and the bench, we
            already have them. The window is open now.
          </p>

          <div class="grid gap-5 md:grid-cols-3">
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Institutional know-how</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                First-hand understanding of how these engagements run day to day — operations, delivery and governance.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">A bench ready to mobilise</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                An established network of vetted cyber specialists and subcontractors who can start at pace.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Continuity, not disruption</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                We turn a supplier transition into momentum — the client keeps moving while we step in.
              </p>
            </div>
          </div>

          <div class="mt-8 rounded-xl border-l-4 border-olive-500 bg-white dark:bg-zinc-900 px-6 py-5">
            <p class="text-base text-zinc-700 dark:text-zinc-200 leading-relaxed">
              The knowledge, the network and the relationships are already on our side. The advantage is real —
              we just need to move before the window closes.
            </p>
          </div>
        </div>
      </section>

      <!-- ── 5. The proof — answering the one question ─────────────────── -->
      <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            The proof
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6 max-w-3xl">
            Answering the one question.
          </h2>
          <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl mb-10">
            CLIENT_X&rsquo;s only real doubt was simple: &ldquo;what cyber experience sits behind the
            consultancy?&rdquo; Here is the answer.
          </p>

          <div class="grid gap-5 md:grid-cols-3 mb-6">
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Cyber, proven</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                A six-figure behaviour-to-cyber transformation for a UK telecoms major —
                repositioning a large organisation&rsquo;s security posture.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Technology at scale</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                A growing case-study workload in cloud, AI and ERP delivery — far beyond a single engagement.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-6">
              <h3 class="text-base font-semibold text-zinc-900 dark:text-white mb-2">Sector reach</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Public and private sector, in regulated environments. Clients anonymised by default; named
                under NDA.
              </p>
            </div>
          </div>

          <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-6 py-5">
            <p class="text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-3">
              Credentials (in progress, honest)
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border border-[var(--warning)]/40 text-[var(--warning)] bg-[var(--warning-soft)]" style="--warning:#d97706;">Cyber Essentials Plus (in progress)</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border border-olive-500/40 text-olive-700 dark:text-olive-400 bg-olive-500/10">ISO 27001 aligned</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border border-[var(--warning)]/40 text-[var(--warning)] bg-[var(--warning-soft)]" style="--warning:#d97706;">ICO registration (pending)</span>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-600 dark:text-zinc-300 bg-zinc-100 dark:bg-zinc-800">GDPR / NIS2 / DORA aware</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ── 6. The risks (TABLE) ──────────────────────────────────────── -->
      <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            The risks — and how we handle them
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6 max-w-3xl">
            We go in with eyes open.
          </h2>
          <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-3xl mb-10">
            We go in with eyes open. Each risk has a play.
          </p>

          <div class="overflow-x-auto rounded-xl border border-zinc-200 dark:border-zinc-800">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-zinc-100 dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800">
                  <th class="px-5 py-3 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400 w-2/5">Risk</th>
                  <th class="px-5 py-3 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">How we handle it</th>
                </tr>
              </thead>
              <tbody class="text-sm align-top">
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60 bg-white dark:bg-zinc-900/40">
                  <td class="px-5 py-4 text-zinc-900 dark:text-zinc-100">
                    <strong>The client must accept moving from the incumbent to Fox &amp; Fifth</strong> — their contract is with the incumbent.
                  </td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    Frame it as <strong class="text-zinc-900 dark:text-white">seamless continuity, not a switch</strong>: same people (the 3+2 assets), sponsored by the buyer, with a dated handover. The client keeps delivery and gains depth.
                  </td>
                </tr>
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60 bg-white dark:bg-zinc-900/40">
                  <td class="px-5 py-4 text-zinc-900 dark:text-zinc-100">
                    <strong>Cyber credibility of the consultancy</strong> (the buyer&rsquo;s one doubt).
                  </td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    Lead with the telecoms cyber case study <strong class="text-zinc-900 dark:text-white">and</strong> StackSolver&rsquo;s technology workload, presented as one team.
                  </td>
                </tr>
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60 bg-white dark:bg-zinc-900/40">
                  <td class="px-5 py-4 text-zinc-900 dark:text-zinc-100">
                    <strong>Due diligence</strong> — the buyer&rsquo;s procurement will review Companies House and financials.
                  </td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    Go in prepared with the full <strong class="text-zinc-900 dark:text-white">procurement pack</strong>: VAT, accounts, director ID, bank reference, registration, Cyber Essentials — presented as combined group capability.
                  </td>
                </tr>
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60 bg-white dark:bg-zinc-900/40">
                  <td class="px-5 py-4 text-zinc-900 dark:text-zinc-100">
                    <strong>Working capital</strong> — the client&rsquo;s payment terms are longer than the payroll cycle.
                  </td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    Put a <strong class="text-zinc-900 dark:text-white">working-capital facility</strong> in place before mobilising the additional assets.
                  </td>
                </tr>
                <tr class="bg-white dark:bg-zinc-900/40">
                  <td class="px-5 py-4 text-zinc-900 dark:text-zinc-100">
                    <strong>Structure must be legally clean.</strong>
                  </td>
                  <td class="px-5 py-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    <strong class="text-zinc-900 dark:text-white">Alliance now</strong> (prime + technology partner — true today), <strong class="text-zinc-900 dark:text-white">group later</strong> (share transfer, via counsel). No &ldquo;subsidiary&rdquo; claim until it is real.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ── 7. How we structure it ────────────────────────────────────── -->
      <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
          <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">
            How we structure it
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-10 max-w-3xl">
            Two phases. Clean and honest.
          </h2>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-7">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-olive-500 text-zinc-900 font-bold text-sm">1</span>
                <h3 class="text-lg font-semibold text-zinc-900 dark:text-white">Now: alliance</h3>
              </div>
              <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Fox &amp; Fifth as prime (contracts, invoices, owns the relationship); StackSolver UK as the
                named Technology, Cyber &amp; AI partner. True today — lets us win the contracts now.
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-7">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-zinc-300 dark:bg-zinc-700 text-zinc-900 dark:text-white font-bold text-sm">2</span>
                <h3 class="text-lg font-semibold text-zinc-900 dark:text-white">Next: group</h3>
              </div>
              <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed">
                Fox &amp; Fifth (or a holding company) takes a shareholding in StackSolver UK, formalising the
                group — handled with legal counsel.
              </p>
            </div>
          </div>

          <div class="mt-8 rounded-xl border-l-4 border-[var(--warning)] bg-[var(--warning-soft)] px-6 py-5" style="--warning:#d97706;">
            <p class="text-base text-zinc-700 dark:text-zinc-200 leading-relaxed">
              <strong class="text-zinc-900 dark:text-white">Open item:</strong>
              Ownership split to be agreed between the partners — the first decision of this meeting.
            </p>
          </div>
        </div>
