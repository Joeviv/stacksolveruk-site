---
// File: src/pages/for/[dept].astro
// Per-department outcome pages, reached from the home perimeter "your departments"
// row. The departments we have written outcomes for render in full; the rest get
// a "coming soon" state (never a silent 404). EN-UK, sentence case.
import Layout from "../../layouts/Layout.astro";
import { DEPARTMENTS, DEPARTMENT_OUTCOMES } from "../../data/sovereignArchitecture";

export function getStaticPaths() {
  return DEPARTMENTS.map((d) => {
    const slug = d.href.replace("/for/", "");
    const written = DEPARTMENT_OUTCOMES.find((o) => o.href === d.href);
    return {
      params: { dept: slug },
      props: { label: d.label, outcome: written?.outcome ?? null },
    };
  });
}

interface Props {
  label: string;
  outcome: string | null;
}
const { label, outcome } = Astro.props as Props;
const seoTitle = `Sovereign AI for ${label} | Fox&Stack`;
const seoDescription = outcome
  ? `What Ethical Sovereign AI does for ${label}: ${outcome}`
  : `Ethical Sovereign AI for ${label} — inside your perimeter, with no data egress, governed to ISO 42001.`;
---

<Layout title={seoTitle} description={seoDescription} type="article">
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 pt-20 pb-14 lg:pt-24">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-olive-600 dark:text-olive-400 mb-8 hover:gap-3 transition-all">
        <span aria-hidden>←</span> Back to the perimeter
      </a>
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">For your team · {label}</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white mb-5">
        Sovereign AI for {label}.
      </h1>
      {outcome ? (
        <p class="text-lg md:text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-2xl">{outcome}</p>
      ) : (
        <p class="text-lg md:text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-2xl">
          AI embedded in {label}, not floating above it — inside your perimeter, with no
          data egress and every interaction logged as evidence.
        </p>
      )}
    </div>
  </section>

  {outcome ? (
    <section class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <div class="font-semibold text-zinc-900 dark:text-white mb-1">No data egress</div>
            <div class="text-sm text-zinc-500 dark:text-zinc-400">Nothing {label} touches leaves your perimeter.</div>
          </div>
          <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <div class="font-semibold text-zinc-900 dark:text-white mb-1">Audit-logged</div>
            <div class="text-sm text-zinc-500 dark:text-zinc-400">Every answer recorded as compliance evidence.</div>
          </div>
          <div class="p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <div class="font-semibold text-zinc-900 dark:text-white mb-1">Governed</div>
            <div class="text-sm text-zinc-500 dark:text-zinc-400">Bounded behaviour, governed to ISO 42001.</div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-sm text-zinc-600 dark:text-zinc-400 mb-6">
          <span class="w-2 h-2 rounded-full bg-olive-500"></span> Outcome page in progress
        </div>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
          We are writing up the {label} outcomes.
        </h2>
        <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-xl mx-auto mb-8">
          The detail for {label} is on its way. Tell us what your team needs and we will
          map it to a sovereign AI outcome directly.
        </p>
      </div>
    </section>
  )}

  <section class="bg-white dark:bg-black">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
        Book a lab demo.
      </h2>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8 max-w-2xl mx-auto">
        See what sovereign AI does for {label}, running inside a real perimeter.
        We will reply within two working days.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Book a lab demo <span aria-hidden>→</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Back to the perimeter
        </a>
      </div>
    </div>
  </section>
</Layout>
