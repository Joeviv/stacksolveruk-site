---
// File: src/pages/model.astro
// Core flow step 02 — Model. Open-weight, auditable, provenance-tracked.
// Verified content: Biblioteca/Sovereign_AI/01_Arquitectura_Referencia_Capas.md (L2)
// and 02_Riesgos_2026_2027_y_ForwardLook.md (poisoning, supply chain → L2). EN-UK.
import LayerPage from "../components/sovereignty/LayerPage.astro";

const points = [
  {
    title: "Open-weight, so you can inspect it",
    body: "An open-weight model you can examine and run yourself — no blind dependency on a black box whose behaviour and terms can change without notice. Model sovereignty means the model is yours to understand.",
  },
  {
    title: "Verified provenance",
    body: "We use vetted, local, provenance-tracked models. Public model hubs host millions of files, and malicious ones are rising sharply — supply chain is now the third-highest OWASP LLM risk — so what we run is sourced and verified, not pulled blind.",
  },
  {
    title: "Signed and safe to load",
    body: "We prefer the safetensors format, which cannot execute code when a model loads, and verify signatures where they exist. The model that runs is the model we vetted, with no hidden payload.",
  },
  {
    title: "Protected against poisoning",
    body: "Tampered weights or fine-tuning data can quietly corrupt how a model behaves. Pre-deployment evaluation and a known, controlled origin keep a poisoned model from ever becoming a trusted one.",
  },
  {
    title: "A model card you can hand over",
    body: "Each model ships with documentation — what it is, how it behaves, where it came from — so governance has an artefact to register and an auditor has something to read.",
  },
  {
    title: "No third party trains on you",
    body: "Because the model is local and the data stays in-house, nobody else learns from your information. The benefit of the model accrues to you, and only to you.",
  },
];

const standards = [
  "Open-weight",
  "Provenance-tracked",
  "safetensors",
  "Model signing",
  "Pre-deploy evaluation",
  "Model cards",
  "Local only",
];

const seoTitle = "Model — open-weight & auditable | Fox&Stack Sovereign AI";
const seoDescription =
  "The model step of Fox&Stack's Sovereign AI core: open-weight, auditable, provenance-tracked models in the safetensors format, signed and evaluated before deployment — protected against poisoning and supply-chain risk, with a model card you can hand to an auditor.";
---

<LayerPage
  eyebrow="Core · 02 model"
  layerTag="The living core · model"
  title="A model you can inspect, not one you must trust blindly."
  lede="The intelligence at the heart of the system, and a sovereign asset in its own right. Open-weight, locally run and provenance-tracked — no blind dependency on a black box, no third party training on your data, and a model card you can hand to a regulator."
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  points={points}
  standards={standards}
>
  <!-- Why model sovereignty matters -->
  <section class="bg-white dark:bg-black border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Why the model is its own kind of sovereignty</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-6">
        Owning the data is not enough if the model is a black box.
      </h2>
      <div class="space-y-5 text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed">
        <p>
          Generative AI made the model an asset in its own right. A model you cannot inspect is
          a dependency you cannot fully govern: you do not know what is inside it, you cannot
          prove how it behaves, and you are exposed if its supplier changes the terms — or if
          the file you downloaded was never what it claimed to be.
        </p>
        <p>
          Sovereignty of the <strong>model</strong>, not just the data, is the part most
          "sovereign" offers leave out. Open weights, verified provenance and a safe load
          format turn the model from a leap of faith into something you can stand behind.
        </p>
      </div>
    </div>
  </section>

  <!-- The flow -->
  <section class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">The flow that stays in-house</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Model is step two of four.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/data" class="group block p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-1">01</div>
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Data</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">kept in-house</div>
        </a>
        <a href="/inference" class="group block p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-1">03</div>
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Inference</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">hardware you own</div>
        </a>
        <a href="/delivery" class="group block p-6 rounded-xl bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 transition-colors">
          <div class="font-mono text-xs text-olive-600 dark:text-olive-400 mb-1">04</div>
          <div class="font-semibold text-zinc-900 dark:text-white group-hover:text-olive-600 dark:group-hover:text-olive-400">Delivery</div>
          <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">audit-logged</div>
        </a>
      </div>
    </div>
  </section>
</LayerPage>
