---
// File: src/pages/library.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Library | Stacksolver UK"
  description="Stacksolver UK research library — articles, frameworks and reference notes on bespoke ERP, GRC, Claris FileMaker and ethical AI."
  robots="noindex, follow"
>
  <section class="min-h-screen flex items-center bg-white dark:bg-black">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-24 text-center">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">Library</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Research notes and reference material.
      </h1>
      <p class="text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed mb-10">
        We publish working notes on Claris FileMaker, GRC implementation, ISO 27001 / 42001 alignment
        and sovereign AI architecture. The library is being curated for public release.
      </p>
      <p class="text-zinc-500 dark:text-zinc-500 italic mb-10">
        First articles will appear here shortly. To request a specific topic or receive notifications,
        please email us.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="mailto:office@stacksolveruk.com?subject=Library%20notification" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Notify me <span aria-hidden>→</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Back home
        </a>
      </div>
    </div>
  </section>
</Layout>
