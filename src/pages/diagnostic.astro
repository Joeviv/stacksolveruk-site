---
// File: src/pages/diagnostic.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Diagnostic | Stacksolver UK"
  description="Free 30-minute diagnostic call with Stacksolver UK. Quick read on whether bespoke ERP, GRC or AI is the right next step for your organisation."
>
  <section class="min-h-screen flex items-center bg-white dark:bg-black">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-24 text-center">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">Diagnostic</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Free 30-minute diagnostic.
      </h1>
      <p class="text-lg text-zinc-700 dark:text-zinc-300 leading-relaxed mb-10">
        Tell us briefly where you are. We will reply within two working days with an honest read on
        whether bespoke ERP, GRC implementation or sovereign AI is the right next step — and whether
        we are the right partner for it.
      </p>
      <p class="text-zinc-500 dark:text-zinc-500 italic mb-10">
        A self-service diagnostic form is being prepared. In the meantime please email us directly.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="mailto:office@stacksolveruk.com?subject=Diagnostic%20enquiry" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Email us <span aria-hidden>→</span>
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Use the contact form
        </a>
      </div>
    </div>
  </section>
</Layout>
