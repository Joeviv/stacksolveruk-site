---
// File: src/pages/index.astro
// Fox&Stack home — Sovereign AI living-perimeter revamp.
// 1) Hero: the enriched perimeter (animated, interactive, dark, full-bleed).
// 2) Built for 2026, ready for 2027 — risk → layer overlay.
// 3) By department — outcomes.
// 4) Trust + CTA.
import Layout from '../layouts/Layout.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import EnrichedPerimeter from '../components/sovereignty/EnrichedPerimeter.astro';
import RiskOverlay from '../components/sovereignty/RiskOverlay.astro';
import { DEPARTMENT_OUTCOMES } from '../data/sovereignArchitecture';

const seoTitle = "Sovereign AI for regulated business — Fox&Stack";
const seoDescription = "Sovereign AI from Fox&Stack: your data stays on-premise in the UK, with built-in guardrails and compliance (ISO 27001, ISO 42001, Cyber Essentials), quantum-ready.";
const seoKeywords = "Sovereign AI, Sovereign AI UK, Ethical Sovereign AI, on-premise AI, no data egress, AI guardrails, ISO 42001, ISO 27001 UK, Cyber Essentials Plus, AI governance, private AI, EU AI Act, NIS2 readiness, quantum-ready, post-quantum cryptography";

const trust = [
  { label: "ISO 27001", sub: "information security" },
  { label: "ISO 42001", sub: "AI management" },
  { label: "Cyber Essentials Plus", sub: "UK baseline" },
  { label: "EU AI Act aligned", sub: "audit-ready" },
];
---

<Layout title={seoTitle} description={seoDescription} keywords={seoKeywords}>
  <!-- HERO: the living perimeter is the star — two columns on desktop (copy left,
       diagram right) so the whole composition fills one screen and uses the full
       width; stacks and centres on mobile. -->
  <section class="hero-dark hero-full relative overflow-hidden flex items-center">
    <div class="relative w-full max-w-7xl mx-auto px-6 lg:px-8 py-12 lg:py-6 grid grid-cols-1 lg:grid-cols-[minmax(0,40%)_minmax(0,60%)] gap-10 lg:gap-12 items-center">
      <!-- Copy — centred on mobile, left-aligned and vertically centred on desktop -->
      <div class="text-center lg:text-left max-w-2xl mx-auto lg:mx-0">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-olive-400 mb-4">
          // inside your perimeter · zero data egress
        </p>
        <h1 class="text-6xl md:text-7xl font-bold tracking-tight text-zinc-400 leading-[1.02] mb-3">
          Sovereign AI
        </h1>
        <p class="text-xl md:text-2xl font-semibold tracking-tight text-white leading-tight mb-5">
          Where your data lives, and what protects it.
        </p>
        <p class="text-base md:text-lg text-zinc-300 leading-relaxed mb-6 max-w-xl mx-auto lg:mx-0">
          Sovereign AI from Fox&Stack. Your departments connect from within, your
          data never leaves, and every layer is something we build in and prove —
          from infrastructure to compliance.
        </p>
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3">
          <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-400 transition-colors">
            Book a lab demo <span aria-hidden>→</span>
          </a>
          <a href="/ethical-sovereign-ai" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-transparent text-white font-medium border border-white/25 hover:border-olive-400 hover:text-olive-300 transition-colors">
            Explore the practice
          </a>
        </div>
        <p class="mt-6 text-xs text-zinc-500">
          Tip — every box, ring and department in the diagram links to its page.
        </p>
      </div>

      <!-- The living diagram — the star, right column on desktop -->
      <div class="hero-diagram w-full rounded-2xl border border-white/10 bg-white/[0.02] p-5 md:p-7">
        <EnrichedPerimeter />
      </div>
    </div>
  </section>

  <!-- Client logo marquee -->
  <ClientMarquee />

  <!-- Built for 2026, ready for 2027 -->
  <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-20">
      <div class="max-w-2xl mb-12">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Credibility · quantum-ready</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Built for 2026, ready for 2027.
        </h2>
        <p class="mt-4 text-zinc-600 dark:text-zinc-400 text-lg">
          The threats facing sovereign AI — and the layer of ours that handles each.
          Tagged for what matters now and what is coming next.
        </p>
      </div>
      <RiskOverlay />
    </div>
  </section>

  <!-- By department -->
  <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-20">
      <div class="max-w-2xl mb-12">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">What it means for you</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          The same perimeter, an outcome for every team.
        </h2>
        <p class="mt-4 text-zinc-600 dark:text-zinc-400 text-lg">
          AI embedded in the function, not floating above it. Here is what sovereign AI
          does for each department — without a single document leaving your control.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {DEPARTMENT_OUTCOMES.map((d) => (
          <a href={d.href} class="group flex flex-col p-7 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 hover:border-olive-500 dark:hover:border-olive-500 transition-colors">
            <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3 group-hover:text-olive-600 dark:group-hover:text-olive-400 transition-colors">{d.label}</h3>
            <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed flex-grow">{d.outcome}</p>
            <span class="mt-5 text-sm font-medium text-olive-600 dark:text-olive-400 inline-flex items-center gap-1">
              See the outcome <span aria-hidden class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
      <p class="mt-8 text-sm text-zinc-500 dark:text-zinc-500">
        Procurement · Finance · HR · Operations · Legal · Sales · Marketing · IT · Security ·
        Customer service · R&D / Product · Data &amp; analytics · Supply chain · Executive / Board —
        the perimeter accommodates them all.
      </p>
    </div>
  </section>

  <!-- Trust + CTA -->
  <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-20">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Auditable by design</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Certified, governed, and provable to your board.
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14">
        {trust.map((t) => (
          <div class="p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-center">
            <div class="font-semibold text-zinc-900 dark:text-white">{t.label}</div>
            <div class="text-xs text-zinc-500 dark:text-zinc-500 mt-1">{t.sub}</div>
          </div>
        ))}
      </div>
      <div class="text-center">
        <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
          Book a lab demo.
        </h3>
        <p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8 max-w-2xl mx-auto">
          See sovereign AI running in our lab — inside a perimeter, with no data egress —
          and tell us about your data, your regulators and your timeline.
          We will reply within two working days.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
            Book a lab demo <span aria-hidden>→</span>
          </a>
          <a href="/trust" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
            Trust Centre
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* The hero aims to fill the viewport on entry (navbar is sticky, 4rem/h-16
     tall) but the diagram is the priority: min-height (never a fixed height)
     lets the section grow with natural scroll when the stacked copy + diagram
     are taller than the viewport, so the full perimeter — departments, rings,
     core, severed path and legend — is always shown and never clipped. dvh
     tracks mobile browser chrome. */
  .hero-full {
    min-height: 100vh;            /* fallback for browsers without dvh */
    min-height: calc(100dvh - 4rem);
  }
  /* When motion is reduced the layout is unchanged; the diagram's own
     animations already honour prefers-reduced-motion in the component. Nothing
     here scrolls or moves, so no further opt-out is required. */

  /* The hero is always dark, regardless of the site theme, to match the
     approved reference aesthetic. */
  .hero-dark {
    background:
      radial-gradient(120% 90% at 80% -10%, rgba(133, 160, 58, 0.14), transparent 60%),
      radial-gradient(90% 70% at 0% 110%, rgba(75, 83, 32, 0.18), transparent 55%),
      #0a0a0a;
    color: #fafafa;
  }
  /* Force the diagram's dark-mode tokens inside the always-dark hero, even when
     the rest of the site is in light mode. */
  .hero-diagram :global(.ep) {
    --ep-bd: rgba(255, 255, 255, 0.12);
    --ep-bd2: rgba(255, 255, 255, 0.22);
    --ep-txt2: #9a9b92;
    --ep-txt3: #6c6d64;
    --ep-surface: rgba(255, 255, 255, 0.02);
    --ep-flow: #a6c04d;
    --ep-core: #a6c04d;
    --ep-sevcol: #f4658f;
    --fg-1: #fafafa;
  }
  .hero-diagram :global(.ep-public-title) { color: #fafafa; }
  .hero-diagram :global(.ep-lg-out) { background: var(--ss-zinc-700); }

  /* Compact the diagram inside the hero so the full perimeter fits one screen.
     Scoped to .hero-diagram only — the component keeps its roomier defaults
     anywhere else it is used. */
  @media (min-width: 1024px) {
    .hero-diagram :global(.ep-depts) { margin-bottom: 8px; }
    .hero-diagram :global(.ep-dept) { padding: 6px 10px; }
    .hero-diagram :global(.ep-governed) { margin: 2px 0 7px; }
    .hero-diagram :global(.ep-ring) { padding: 8px 13px 8px; }
    .hero-diagram :global(.ep-timeline) { margin-bottom: 5px; gap: 2px; }
    .hero-diagram :global(.ep-rhead) { padding: 2px 0 5px; }
    .hero-diagram :global(.ep-core) { padding: 8px 13px 9px; }
    .hero-diagram :global(.ep-core-head) { padding: 2px 0 6px; }
    .hero-diagram :global(.ep-severed) { margin: 2px 0; }
    .hero-diagram :global(.ep-public) { margin: 2px auto 8px; }
  }
</style>
