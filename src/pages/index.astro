---
// File: src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import HeroV2 from '../components/hero/HeroV2';

const seoTitle = "Stacksolver UK | Claris FileMaker Partner, GRC & ERP Experts (+18 years)";
const seoDescription = "Brighton-based technology consultancy serving the United Kingdom, Europe and the United States. GRC and ERP systems, bespoke Claris FileMaker apps (+18 years) and ISO-grade AI implementation.";
const seoKeywords = "Claris FileMaker Partner UK, Bespoke ERP UK, GRC Consultancy UK, ISO 27001 UK, ISO 42001 AI, Sovereign AI, British Software Company, FileMaker Consultancy Europe";
---

<Layout title={seoTitle} description={seoDescription} keywords={seoKeywords}>
  <HeroV2 client:load />

  <!-- Intro section -->
  <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-20 grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-1">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">Who we are</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          A British technology consultancy.
        </h2>
      </div>
      <div class="lg:col-span-2 space-y-5 text-zinc-700 dark:text-zinc-300 text-lg leading-relaxed">
        <p>
          Stacksolver UK Limited is a Brighton-based consultancy serving organisations across the
          <strong>United Kingdom, Europe and the United States</strong>. We design and deliver bespoke
          enterprise systems where governance, risk and compliance are not bolted on — they are built in.
        </p>
        <p>
          Our work spans <strong>tailored ERP development</strong>, <strong>Claris FileMaker</strong> bespoke applications
          (+18 years on the platform), <strong>ISO 27001 and ISO 42001</strong> implementation, and <strong>sovereign AI</strong>
          deployments where every byte stays inside your perimeter.
        </p>
        <p>
          We work primarily with <strong>regulated industries</strong>: fiduciary services, corporate services,
          legal, financial services and AI-sensitive sectors where audit trails and data sovereignty are not optional.
        </p>
      </div>
    </div>
  </section>

  <!-- Pillars section -->
  <section class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-20">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-4">What we do</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white">
          Four pillars. One coherent practice.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/services/erp-filemaker" class="group block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-olive-500 dark:hover:border-olive-500 transition-colors">
          <div class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-3">Claris FileMaker</div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Bespoke ERP</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">Finance, HR, projects, inventory and operations in one tailored system.</p>
        </a>

        <a href="/services/grc" class="group block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-olive-500 dark:hover:border-olive-500 transition-colors">
          <div class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-3">ISO 27001 · 42001</div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Native GRC</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">Automated audits and regulatory compliance embedded in every transaction.</p>
        </a>

        <a href="/services/ai-local" class="group block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-olive-500 dark:hover:border-olive-500 transition-colors">
          <div class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-3">Zero data egress</div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Sovereign AI</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">Specialised agents inside your perimeter. Immutable audit logs, audit-ready.</p>
        </a>

        <a href="/services/apple-business" class="group block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl hover:border-olive-500 dark:hover:border-olive-500 transition-colors">
          <div class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-3">ABM · MDM · VPP</div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Apple Business</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">Apple Business Manager rollout and support. Corporate accounts, MDM, training.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="bg-white dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-white mb-4">
        Ready to talk?
      </h2>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 mb-8 max-w-2xl mx-auto">
        Tell us about your project, your constraints and your timeline. We will reply within two working days.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Contact us <span aria-hidden>→</span>
        </a>
        <a href="/diagnostic" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Start a diagnostic
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 py-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
      <div>
        <div class="font-bold text-zinc-900 dark:text-white mb-2">Stacksolver UK Limited</div>
        <p class="text-zinc-600 dark:text-zinc-400">Company Number 16227080</p>
        <p class="text-zinc-600 dark:text-zinc-400">215 Ditchling Road,<br />Brighton, BN1 6JD<br />United Kingdom</p>
      </div>
      <div>
        <div class="font-semibold text-zinc-900 dark:text-white mb-2">Sitemap</div>
        <ul class="space-y-1">
          <li><a href="/" class="text-zinc-600 dark:text-zinc-400 hover:text-olive-500">Home</a></li>
          <li><a href="/about" class="text-zinc-600 dark:text-zinc-400 hover:text-olive-500">About</a></li>
          <li><a href="/method" class="text-zinc-600 dark:text-zinc-400 hover:text-olive-500">Method</a></li>
          <li><a href="/contact" class="text-zinc-600 dark:text-zinc-400 hover:text-olive-500">Contact</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold text-zinc-900 dark:text-white mb-2">Get in touch</div>
        <p class="text-zinc-600 dark:text-zinc-400">
          <a href="mailto:office@stacksolveruk.com" class="hover:text-olive-500">office@stacksolveruk.com</a>
        </p>
        <p class="text-zinc-600 dark:text-zinc-400 mt-3 text-xs">
          © {new Date().getFullYear()} Stacksolver UK Limited. All rights reserved.
        </p>
      </div>
    </div>
  </footer>
</Layout>
