---
// File: src/pages/services/apple-business.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Apple Business Manager — Implementation & Support | Stacksolver UK"
  description="Apple Business Manager rollout for organisations standardising on Apple devices. Corporate accounts, Managed Apple IDs, MDM integration (Jamf, Mosyle, Kandji), training and ongoing support."
  keywords="Apple Business Manager UK, ABM consultant UK, Managed Apple IDs, MDM Jamf Mosyle Kandji, Apple fleet management, VPP, DEP"
>
  <section class="min-h-screen bg-white dark:bg-black">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-24">
      <p class="text-xs font-mono uppercase tracking-widest text-olive-600 dark:text-olive-400 mb-6">Apple Business</p>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-white mb-8">
        Apple Business Manager rollout, end to end.
      </h1>
      <p class="text-xl text-zinc-700 dark:text-zinc-300 leading-relaxed mb-12 max-w-3xl">
        We help organisations standardising on Apple devices set up Apple Business Manager,
        federate corporate identity, integrate with their MDM of choice and train internal teams.
        For fleets ranging from 10 to 500 devices.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        <div class="p-6 bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl border border-zinc-200 dark:border-zinc-800">
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Setup engagement</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">Fixed-scope project: ABM portal configuration, Managed Apple IDs, federation, MDM enrolment, VPP and DEP setup, internal training.</p>
        </div>
        <div class="p-6 bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl border border-zinc-200 dark:border-zinc-800">
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Ongoing support</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">Monthly retainer covering operational support, MDM updates, onboarding flows for new joiners and quarterly fleet reviews.</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-16 text-xs font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-500">
        <div class="px-3 py-2 border border-zinc-200 dark:border-zinc-800 rounded-md text-center">ABM</div>
        <div class="px-3 py-2 border border-zinc-200 dark:border-zinc-800 rounded-md text-center">MDM</div>
        <div class="px-3 py-2 border border-zinc-200 dark:border-zinc-800 rounded-md text-center">VPP</div>
        <div class="px-3 py-2 border border-zinc-200 dark:border-zinc-800 rounded-md text-center">DEP</div>
      </div>

      <p class="text-zinc-500 dark:text-zinc-500 italic pt-8 mb-10 border-t border-zinc-200 dark:border-zinc-800">
        Detailed engagement scope, deliverables and pricing are being prepared. For specific
        requirements please email <a href="mailto:office@stacksolveruk.com" class="text-olive-600 dark:text-olive-400 hover:underline">office@stacksolveruk.com</a>.
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-olive-500 text-zinc-900 font-semibold border border-olive-500 hover:bg-olive-600 transition-colors">
          Discuss your fleet <span aria-hidden>→</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-transparent text-zinc-900 dark:text-white font-medium border border-olive-500 hover:bg-olive-500/10 transition-colors">
          Back home
        </a>
      </div>
    </div>
  </section>
</Layout>
