---
// File: src/pages/services/[sectionId]/index.astro
import Layout from "../../../layouts/Layout.astro";
import { SERVICES_MENU } from "../../../data/menuData";
import {
  ChevronRightIcon,
  ArrowLongRightIcon,
} from "@heroicons/react/24/outline";

export const prerender = true;

export async function getStaticPaths() {
  return SERVICES_MENU.map((section) => ({
    params: { sectionId: section.id },
    props: { section },
  }));
}

const { section } = Astro.props;
const { title, subsections } = section;

const getDescription = (id: string) => {
  switch (id) {
    case "ai-local":
      return "Sovereign AI deployments that run entirely inside your perimeter. Data sovereignty, audit-ready logs and zero data egress.";
    case "erp-filemaker":
      return "Bespoke ERP development on Claris FileMaker — finance, HR, projects, inventory and operations in one tailored system.";
    case "grc":
      return "Governance, Risk and Compliance platforms that align with ISO 27001, ISO 42001 and the EU AI Act.";
    case "apple-business":
      return "Apple Business Manager rollout, MDM integration, Managed Apple IDs and ongoing support for organisations standardising on Apple devices.";
    default:
      return "Bespoke technology solutions for regulated industries.";
  }
};

const fullDescription = getDescription(section.id);
---

<Layout title={`${title} | Fox&Stack Services`} description={fullDescription}>
  <div class="p-6 md:p-12 lg:p-16 max-w-7xl mx-auto w-full">
    <div class="flex items-center gap-2 text-sm text-zinc-500 mb-8">
      <a href="/" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Home</a>
      <ChevronRightIcon className="w-3 h-3" />
      <span class="text-olive-500 dark:text-olive-400 font-medium">{title}</span>
    </div>

    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-zinc-900 dark:text-white mb-6 tracking-tight">
        {title}
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed font-light">
        {fullDescription}
      </p>
    </div>

    <h2 class="text-3xl font-bold text-zinc-900 dark:text-white mb-8">
      Our solutions in {title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        subsections.map((sub) => (
          <a
            href={`/services/${section.id}/${sub.id}`}
            class="group relative flex flex-col p-8 bg-zinc-50 dark:bg-zinc-900/50 rounded-3xl border border-zinc-200 dark:border-zinc-800 hover:border-olive-500/50 dark:hover:border-olive-500/50 transition-all duration-300 hover:shadow-lg dark:hover:shadow-olive-900/5"
          >
            <div class="mb-4 text-zinc-900 dark:text-white group-hover:text-olive-500 dark:group-hover:text-olive-400 transition-colors">
              <h3 class="text-xl font-bold">{sub.title}</h3>
            </div>

            <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-6 flex-grow">
              {sub.shortDescription}
            </p>

            <div class="flex items-center text-olive-500 dark:text-olive-400 text-sm font-medium">
              View details
              <ArrowLongRightIcon className="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" />
            </div>
          </a>
        ))
      }
    </div>

    <p class="text-zinc-500 dark:text-zinc-500 italic mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
      Detailed pages for each sub-solution are being prepared. For specific scope and pricing
      please email <a href="mailto:hello@foxfifth.com" class="text-olive-600 dark:text-olive-400 hover:underline">hello@foxfifth.com</a>.
    </p>
  </div>
</Layout>
