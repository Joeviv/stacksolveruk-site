---
// File: src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';
import { EnvelopeIcon, MapPinIcon, BuildingOffice2Icon } from '@heroicons/react/24/outline';
---

<Layout
  title="Contact | Stacksolver UK"
  description="Talk to us about Cyber Security, AI Engineering, Compliance or NIS2 / DORA programmes. We reply within two working days."
>
  <div class="min-h-screen flex flex-col justify-center p-6 md:p-12">

    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div class="space-y-8">
        <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 dark:text-white tracking-tight">
          Let's talk about <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-olive-500 to-olive-600 dark:from-olive-500 dark:to-olive-600">your next engagement.</span>
        </h1>
        <p class="text-zinc-600 dark:text-zinc-400 text-lg leading-relaxed max-w-md">
          Cyber, AI, GRC, ISO, NIS2 / DORA — pick the area, tell us the problem, and we will reply within two working days with a clear next step.
        </p>

        <div class="space-y-6 pt-8 border-t border-zinc-200 dark:border-zinc-800">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-white border border-zinc-200 rounded-lg dark:bg-zinc-900 dark:border-zinc-800 shadow-sm dark:shadow-none">
              <EnvelopeIcon className="w-6 h-6 text-olive-500 dark:text-olive-500" />
            </div>
            <div>
              <h3 class="text-zinc-900 dark:text-white font-medium mb-1">Email</h3>
              <a href="mailto:hello@foxfifth.com" class="text-zinc-600 hover:text-olive-500 dark:text-zinc-400 dark:hover:text-white transition-colors">hello@foxfifth.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="p-3 bg-white border border-zinc-200 rounded-lg dark:bg-zinc-900 dark:border-zinc-800 shadow-sm dark:shadow-none">
              <BuildingOffice2Icon className="w-6 h-6 text-olive-600 dark:text-olive-500" />
            </div>
            <div>
              <h3 class="text-zinc-900 dark:text-white font-medium mb-1">Stacksolver UK Limited</h3>
              <p class="text-zinc-600 dark:text-zinc-400">Company Number 16227080</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="p-3 bg-white border border-zinc-200 rounded-lg dark:bg-zinc-900 dark:border-zinc-800 shadow-sm dark:shadow-none">
              <MapPinIcon className="w-6 h-6 text-olive-600 dark:text-olive-500" />
            </div>
            <div>
              <h3 class="text-zinc-900 dark:text-white font-medium mb-1">Registered Office</h3>
              <p class="text-zinc-600 dark:text-zinc-400">215 Ditchling Road,<br />Brighton, BN1 6JD,<br />United Kingdom</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white border border-zinc-200 dark:bg-zinc-900/30 dark:border-zinc-800 rounded-3xl p-6 md:p-10 backdrop-blur-sm shadow-xl dark:shadow-2xl">
        <ContactForm client:load />
      </div>

    </div>
  </div>
</Layout>
